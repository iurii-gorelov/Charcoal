# Format:
#
# id/name: str           | name of the entity
# id/charinfo: str       | character to render [0] - character, [1] - foreground color
# id/collision: 0/1      | is entity collidable
# id/health: num         | health

# Player
0/name:      "player"
0/charinfo:  "n0"
0/collision: 1
0/health:    6

# Projectile
1/name:      "projectile"
1/charinfo:  "h1"
1/collision: 0
1/health:    1

# Drop
2/name:      "drop"
2/charinfo:  "^1"
2/collision: 0
2/health:    0